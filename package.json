{
    "name": "apple1js",
    "version": "2.0.0",
    "description": "2K3 modern version of Apple 1 JS by stid",
    "type": "module",
    "browserslist": "> 0.5%, last 2 versions, not dead",
    "repository": "git@github.com:stid/Apple1JS.git",
    "author": "Stefano Furiosi <stid72@gmail.com>",
    "license": "MIT",
    "scripts": {
        "dev": "run-s wasm:build:release dev:vite",
        "dev:debug-wasm": "run-s wasm:build:dev dev:vite",
        "dev:vite": "vite",
        "build": "run-s wasm:build:release tsc vite:build",
        "vite:build": "vite build",
        "preview": "vite preview",
        "wasm:build": "cd wasm-cpu && wasm-pack build --dev --target web --out-dir ../src/wasm",
        "wasm:build:dev": "cd wasm-cpu && wasm-pack build --dev --target web --out-dir ../src/wasm",
        "wasm:build:release": "cd wasm-cpu && wasm-pack build --release --target web --out-dir ../src/wasm",
        "wasm:clean": "rm -rf src/wasm",
        "wasm:check": "cd wasm-cpu && cargo check",
        "wasm:test": "cd wasm-cpu && cargo test",
        "wasm:verify": "node scripts/check-wasm-build.js",
        "tsc": "tsc --build ./tsconfig.json",
        "pretest": "run-s lint type-check",
        "test": "vitest --silent",
        "test:watch": "vitest --watch",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest --coverage",
        "test:ci": "run-s pretest vitest:ci",
        "vitest:ci": "vitest run --reporter=default --reporter=junit --silent",
        "lint": "eslint './src/**/*.{js,jsx,ts,tsx}'",
        "lint:fix": "eslint --fix './src/**/*.{js,jsx,ts,tsx}'",
        "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules'",
        "lint:md:fix": "markdownlint-cli2 --fix '**/*.md' '#node_modules'",
        "format": "prettier --write './**/*.{js,jsx,ts,tsx,css,md,json}' --config ./.prettierrc",
        "type-check": "tsc --build ./tsconfig.json",
        "clean": "rm -rf dist coverage",
        "bundle-size": "vite build && du -sh dist"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "@eslint/js": "^9.39.4",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^25.9.1",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "@typescript-eslint/eslint-plugin": "^8.36.0",
        "@typescript-eslint/parser": "^8.36.0",
        "@vitejs/plugin-react": "6.0.2",
        "@vitest/ui": "^4.1.7",
        "autoprefixer": "^10.4.21",
        "cssnano": "^7.0.7",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.5",
        "eslint-plugin-jest": "^29.0.1",
        "eslint-plugin-prettier": "^5.5.1",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "happy-dom": "^20.9.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "markdownlint-cli2": "^0.22.1",
        "npm-run-all": "^4.1.5",
        "postcss": "^8.5.6",
        "prettier": "^3.6.2",
        "tailwindcss": "^3.4.17",
        "terser": "^5.43.1",
        "typescript": "^6.0.3",
        "vite": "8.0.14",
        "vitest": "^4.1.7"
    },
    "dependencies": {
        "comlink": "^4.4.2",
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "waait": "^1.0.5"
    }
}
