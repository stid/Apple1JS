# Claude Code — machine-local: personal permission grants + hook wiring (never commit)
.claude/settings.local.json
# Claude Code — active hooks kept local so fork PRs can't inject auto-executing code
# (reference copies live in .claude/hooks.example/). The maintainer's settings.local.json
# wires .claude/hooks/*.sh by path, so this dir must stay untracked.
.claude/hooks/
